#!/usr/bin/env python3

from __future__ import annotations

import argparse
import re
from collections import defaultdict
from pathlib import Path


KNOWN_TYPES = {"meeting", "report", "goal", "design", "guide", "research", "plan", "note"}
RELATIVE_TIME_PATTERN = re.compile(
    r"今天|昨天|明天|后天|本周|下周|上周|刚才|近期|上次|下次|本月|上月|下月|最近[一二三四五六七八九十\d]*(天|周|月)"
)


def iter_journal_files(root: Path, month: str | None) -> list[Path]:
    directories = []
    if month:
        directories = [root / month]
    else:
        directories = sorted(path for path in root.iterdir() if path.is_dir() and re.fullmatch(r"\d{4}", path.name))

    files: list[Path] = []
    for directory in directories:
        if directory.is_dir():
            files.extend(sorted(directory.glob("*.md")))
    return files


def split_frontmatter(text: str) -> tuple[str, str]:
    if text.startswith("---\n"):
        end = text.find("\n---\n", 4)
        if end != -1:
            return text[4:end], text[end + 5 :]
    return "", text


def parse_tags(block: str) -> list[str]:
    for line in block.splitlines():
        if line.startswith("tags:"):
            tail = line[len("tags:") :].strip()
            if tail.startswith("[") and tail.endswith("]"):
                return [item.strip().strip("'\"") for item in tail[1:-1].split(",") if item.strip()]
    return []


def parse_summary(block: str) -> str:
    match = re.search(r'^summary:\s*(.+?)\s*$', block, re.M)
    if not match:
        return ""
    value = match.group(1).strip()
    if value in {"", '""', "''"}:
        return ""
    return value.strip("'\"")


def has_h1(body: str) -> bool:
    return any(line.startswith("# ") for line in body.splitlines()[:20])


def unsupported_keys(block: str) -> list[str]:
    keys = []
    for line in block.splitlines():
        if not line or line.startswith(" ") or ":" not in line:
            continue
        key = line.split(":", 1)[0].strip()
        if key not in {"tags", "summary"}:
            keys.append(key)
    return keys


def main() -> int:
    parser = argparse.ArgumentParser(description="Audit journal quality and secretary-maintenance baseline.")
    parser.add_argument("--month", help="只检查某个月目录，例如 2603。")
    parser.add_argument("--list", action="store_true", help="列出问题文件。")
    args = parser.parse_args()

    root = Path(__file__).resolve().parents[2]
    files = iter_journal_files(root, args.month)
    issues: dict[str, list[str]] = defaultdict(list)

    for path in files:
        text = path.read_text(encoding="utf-8", errors="ignore")
        block, body = split_frontmatter(text)
        tags = parse_tags(block)
        summary = parse_summary(block)
        top = "\n".join(body.splitlines()[:40])

        if not block:
            issues["missing_frontmatter"].append(str(path.relative_to(root)))
        if not summary:
            issues["missing_summary"].append(str(path.relative_to(root)))
        if "journal" not in tags:
            issues["missing_journal_tag"].append(str(path.relative_to(root)))
        if not any(tag in KNOWN_TYPES for tag in tags):
            issues["missing_type_tag"].append(str(path.relative_to(root)))
        if unsupported_keys(block):
            issues["unsupported_frontmatter_keys"].append(str(path.relative_to(root)))
        if not has_h1(body):
            issues["missing_h1"].append(str(path.relative_to(root)))
        if RELATIVE_TIME_PATTERN.search(top):
            issues["relative_time_in_top"].append(str(path.relative_to(root)))

    print(f"files={len(files)}")
    for key in sorted(issues):
        print(f"{key}={len(issues[key])}")
    if args.list:
        for key in sorted(issues):
            print(f"\n[{key}]")
            for item in issues[key]:
                print(item)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
