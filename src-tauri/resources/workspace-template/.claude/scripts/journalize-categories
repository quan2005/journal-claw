#!/usr/bin/env python3

from __future__ import annotations

import argparse
import os
import posixpath
import re
import subprocess
from datetime import datetime
from pathlib import Path


LINK_PATTERN = re.compile(r'(!?\[[^\]]*\]\()([^)#]+)(#[^)]+)?(\))')
DATE_YMD_PATTERN = re.compile(r'(20\d{2})[-_/年.](\d{1,2})[-_/月.](\d{1,2})')
DATE_COMPACT_PATTERN = re.compile(r'(20\d{2})(\d{2})(\d{2})')


def run_git(root: Path, *args: str) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=root,
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout


def git_root(cwd: Path) -> Path:
    return Path(run_git(cwd, "rev-parse", "--show-toplevel").strip())


def resolve_source_path(current_rel: str) -> str:
    if current_rel.startswith("refs/"):
        return current_rel[len("refs/") :]
    return current_rel


def companion_suffix(path: Path) -> str:
    if path.suffix.lower() != ".md":
        return ""
    return Path(path.stem).suffix.lower()


def first_commit_date(root: Path, current_rel: str, extra_candidates: list[str] | None = None) -> str | None:
    candidates = []
    for candidate in [resolve_source_path(current_rel), current_rel, *(extra_candidates or [])]:
        if candidate and candidate not in candidates:
            candidates.append(candidate)

    for candidate in candidates:
        output = run_git(
            root,
            "log",
            "--follow",
            "--diff-filter=A",
            "--format=%ad",
            "--date=short",
            "--",
            candidate,
        ).strip().splitlines()
        if output:
            return output[-1]
    return None


def parse_date_from_text(text: str) -> str | None:
    head = "\n".join(text.splitlines()[:80])
    if text.startswith("---\n"):
        _, _, after = text.partition("\n---\n")
        frontmatter = text[: len(text) - len(after) - 5]
        match = re.search(r'^date:\s*"?([0-9]{4}-[0-9]{2}-[0-9]{2})"?$', frontmatter, re.M)
        if match:
            return match.group(1)

    match = DATE_YMD_PATTERN.search(head)
    if match:
        year, month, day = match.groups()
        return f"{year}-{int(month):02d}-{int(day):02d}"

    match = DATE_COMPACT_PATTERN.search(head)
    if match:
        year, month, day = match.groups()
        return f"{year}-{month}-{day}"

    return None


def parse_date_from_name(name: str) -> str | None:
    match = DATE_YMD_PATTERN.search(name)
    if match:
        year, month, day = match.groups()
        return f"{year}-{int(month):02d}-{int(day):02d}"

    match = DATE_COMPACT_PATTERN.search(name)
    if match:
        year, month, day = match.groups()
        return f"{year}-{month}-{day}"

    return None


def derive_date(root: Path, path: Path, current_rel: str) -> str:
    companion_ext = companion_suffix(path)
    if path.suffix.lower() == ".md" and companion_ext not in {
        ".pdf",
        ".ppt",
        ".pptx",
        ".doc",
        ".docx",
        ".xls",
        ".xlsx",
        ".html",
    }:
        text = path.read_text(encoding="utf-8", errors="ignore")
        text_date = parse_date_from_text(text)
        if text_date:
            return text_date

    name_date = parse_date_from_name(path.name)
    if name_date:
        return name_date

    extra_candidates = []
    if companion_ext:
        companion_rel = current_rel[: -len(".md")]
        extra_candidates.extend([resolve_source_path(companion_rel), companion_rel])

    commit_date = first_commit_date(root, current_rel, extra_candidates)
    if commit_date:
        return commit_date

    stat = path.stat()
    return datetime.fromtimestamp(stat.st_mtime).strftime("%Y-%m-%d")


def sanitize_title(value: str) -> str:
    value = value.replace("_", "-").replace("/", "-").replace("：", "-").replace(":", "-")
    value = re.sub(r"\s+", "", value)
    value = re.sub(r"[\\*?\"<>|]", "", value)
    value = re.sub(r"[^\w\u4e00-\u9fff（）()《》\-+.&]", "", value)
    value = re.sub(r"^-+", "", value)
    return value.strip(".- ")


def stem_to_title(path: Path) -> str:
    stem = path.stem
    if path.suffix.lower() == ".md" and Path(stem).suffix.lower() in {
        ".pdf",
        ".ppt",
        ".pptx",
        ".doc",
        ".docx",
        ".xls",
        ".xlsx",
        ".html",
    }:
        stem = Path(stem).stem
    stem = re.sub(r"^\d{2}-", "", stem)
    stem = stem.replace("README-", "").replace("README", "")
    stem = sanitize_title(stem)
    if stem:
        return stem
    return sanitize_title(path.parent.name)


def heading_title(text: str) -> str | None:
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("#"):
            title = re.sub(r"^#+\s*", "", stripped)
            title = sanitize_title(title)
            if title and len(title) <= 48:
                return title
    return None


def derive_title(path: Path) -> str:
    if path.name.lower() == "readme.md":
        return sanitize_title(path.parent.name) + "总览"

    if path.suffix.lower() == ".md":
        stem_title = stem_to_title(path)
        companion_suffix = Path(path.stem).suffix.lower()
        if companion_suffix in {".pdf", ".ppt", ".pptx", ".doc", ".docx", ".xls", ".xlsx", ".html"}:
            return stem_title
        text = path.read_text(encoding="utf-8", errors="ignore")
        heading = heading_title(text)
        if heading and (not stem_title or len(stem_title) <= 3 or re.fullmatch(r"[A-Za-z0-9-]+", stem_title)):
            return heading
        if stem_title:
            return stem_title

    return stem_to_title(path)


def ensure_unique(target: str, used: set[str]) -> str:
    if target not in used:
        used.add(target)
        return target

    base, ext = os.path.splitext(target)
    index = 2
    while True:
        candidate = f"{base}-{index:02d}{ext}"
        if candidate not in used:
            used.add(candidate)
            return candidate
        index += 1


def update_frontmatter(text: str) -> str:
    required = [
        "tags: [journal]",
        'summary: ""',
    ]

    if text.startswith("---\n") and "\n---\n" in text:
        _, _, body = text.partition("\n---\n")
        block = text[4 : len(text) - len(body) - 5]
        lines = block.splitlines()
        cleaned: list[str] = []
        skip_list = False
        for line in lines:
            if re.match(r"^(date|source_path|summary):", line):
                skip_list = False
                continue
            if re.match(r"^(tags|aliases):", line):
                skip_list = True
                continue
            if skip_list:
                if line.startswith(" ") or line.startswith("\t") or not line.strip():
                    continue
                skip_list = False
            if not skip_list and line.strip():
                cleaned.append(line)
        frontmatter = "---\n" + "\n".join(required + cleaned) + "\n---\n"
        return frontmatter + body.lstrip("\n")

    frontmatter = "---\n" + "\n".join(required) + "\n---\n\n"
    return frontmatter + text.lstrip("\n")


def rewrite_links(
    text: str,
    current_rel: str,
    new_rel: str,
    move_map: dict[str, str],
    existing_files: set[str],
) -> str:
    def replace(match: re.Match[str]) -> str:
        target = match.group(2).strip()
        if not target or "://" in target or target.startswith("mailto:") or target.startswith("#"):
            return match.group(0)

        if target.startswith("/"):
            return match.group(0)

        resolved = posixpath.normpath(posixpath.join(posixpath.dirname(current_rel), target))
        mapped = move_map.get(resolved)

        if not mapped and resolved in existing_files:
            mapped = resolved

        if not mapped and (Path(resolved).name == "" or resolved.endswith("/")):
            candidate = posixpath.join(resolved.rstrip("/"), "README.md")
            mapped = move_map.get(candidate)
            if not mapped and candidate in existing_files:
                mapped = candidate

        if not mapped:
            candidate = posixpath.join(resolved, "README.md")
            mapped = move_map.get(candidate)
            if not mapped and candidate in existing_files:
                mapped = candidate

        if not mapped:
            return match.group(0)

        relative = posixpath.relpath(mapped, posixpath.dirname(new_rel))
        return f"{match.group(1)}{relative}{match.group(3) or ''}{match.group(4)}"

    return LINK_PATTERN.sub(replace, text)


def build_target_path(root: Path, path: Path, used: set[str]) -> str:
    current_rel = path.relative_to(root).as_posix()
    date = derive_date(root, path, current_rel)
    if not isinstance(date, str):
        raise RuntimeError(f"Invalid date for {current_rel}")
    month = date[2:4] + date[5:7]
    day = date[8:10]
    title = derive_title(path)
    if not title:
        title = sanitize_title(path.stem) or "未命名"
    if path.suffix.lower() == ".md":
        if len(path.suffixes) >= 2 and path.suffixes[-2].lower() in {
            ".pdf",
            ".ppt",
            ".pptx",
            ".doc",
            ".docx",
            ".xls",
            ".xlsx",
            ".html",
        }:
            extension = "".join(path.suffixes[-2:])
        else:
            extension = ".md"
    else:
        extension = path.suffix
    if path.name.startswith("."):
        extension = ""
        title = "临时文件"
    target = f"{month}/{day}-{title}{extension}"
    return ensure_unique(target, used)


def iter_target_paths(root: Path, categories: list[str]) -> tuple[list[Path], list[Path]]:
    md_files: list[Path] = []
    assets: list[Path] = []
    for category in categories:
        base = root / category
        for path in sorted(base.rglob("*")):
            if not path.is_file():
                continue
            if path.suffix.lower() == ".md":
                md_files.append(path)
            else:
                assets.append(path)
    return md_files, assets


def main() -> None:
    parser = argparse.ArgumentParser(description="Move refs category content into journal directories.")
    parser.add_argument("categories", nargs="+", help="Category directories to migrate, for example refs/03-AI智能体")
    parser.add_argument("--dry-run", action="store_true", help="Only print the planned mapping")
    args = parser.parse_args()

    root = git_root(Path.cwd())
    categories = [category.rstrip("/") for category in args.categories]
    md_files, assets = iter_target_paths(root, categories)

    used_targets = {p.relative_to(root).as_posix() for p in root.rglob("*") if p.is_file()}
    move_map: dict[str, str] = {}

    for path in md_files + assets:
        current_rel = path.relative_to(root).as_posix()
        target = build_target_path(root, path, used_targets)
        move_map[current_rel] = target

    if args.dry_run:
        for old, new in sorted(move_map.items()):
            print(f"{old} -> {new}")
        return

    existing_files = {p.relative_to(root).as_posix() for p in root.rglob("*") if p.is_file()}
    md_payload: dict[str, tuple[str, str]] = {}

    for path in md_files:
        current_rel = path.relative_to(root).as_posix()
        target_rel = move_map[current_rel]
        text = path.read_text(encoding="utf-8", errors="ignore")
        rewritten = rewrite_links(text, current_rel, target_rel, move_map, existing_files)
        final = update_frontmatter(rewritten)
        md_payload[current_rel] = (target_rel, final)

    global_md_updates: dict[Path, str] = {}
    for md in sorted(root.rglob("*.md")):
        current_rel = md.relative_to(root).as_posix()
        if current_rel in md_payload:
            continue
        original = md.read_text(encoding="utf-8", errors="ignore")
        rewritten = rewrite_links(original, current_rel, current_rel, move_map, existing_files)
        if rewritten != original:
            global_md_updates[md] = rewritten

    for old_rel, new_rel in move_map.items():
        destination = root / new_rel
        destination.parent.mkdir(parents=True, exist_ok=True)
        subprocess.run(["git", "mv", old_rel, new_rel], cwd=root, check=True)

    for _, (new_rel, content) in md_payload.items():
        (root / new_rel).write_text(content, encoding="utf-8")

    for path, content in global_md_updates.items():
        path.write_text(content, encoding="utf-8")

    for category in categories:
        base = root / category
        if base.exists():
            for directory in sorted(base.rglob("*"), reverse=True):
                if directory.is_dir():
                    try:
                        directory.rmdir()
                    except OSError:
                        pass
            try:
                base.rmdir()
            except OSError:
                pass

    print(f"migrated markdown: {len(md_files)}")
    print(f"migrated assets: {len(assets)}")


if __name__ == "__main__":
    main()
