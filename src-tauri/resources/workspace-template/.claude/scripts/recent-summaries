#!/usr/bin/env bash
set -euo pipefail

LIMIT=10

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--limit) LIMIT="$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Collect: mtime, path, summary
declare -a entries=()

while IFS= read -r -d '' file; do
  summary=$(awk '
    /^---$/ { count++; next }
    count == 1 && /^summary:/ {
      sub(/^summary:[[:space:]]*/, "")
      gsub(/^["'"'"']|["'"'"']$/, "")
      print
      exit
    }
  ' "$file")
  mtime=$(stat -f "%m" "$file" 2>/dev/null || stat -c "%Y" "$file")
  summary="${summary:-[缺少 summary]}"
  if [[ "$summary" =~ [一-龥] ]]; then max_len=80; else max_len=300; fi
  [[ ${#summary} -gt $max_len ]] && summary="${summary:0:$((max_len-1))}…"
  entries+=("${mtime}	${file}	${summary}")
done < <(find "$REPO_ROOT" -maxdepth 2 -mindepth 2 -name "*.md" \
  -not -path "$REPO_ROOT/.claude/*" \
  -regex ".*/[0-9][0-9][0-9][0-9]/.*" \
  -print0)

# Sort by mtime descending
IFS=$'\n' sorted=($(printf '%s\n' "${entries[@]}" | sort -rn))
unset IFS

count=0
for entry in "${sorted[@]}"; do
  [[ $count -ge $LIMIT ]] && break
  mtime="${entry%%	*}"
  rest="${entry#*	}"
  file="${rest%%	*}"
  summary="${rest#*	}"
  rel="${file#$REPO_ROOT/}"
  printf -- "%d. %s\n   > %s\n" "$((count+1))" "$rel" "$summary"
  count=$((count+1))
done

# Identity profiles summary
IDENTITY_DIR="${REPO_ROOT}/identity"
if [[ -d "${IDENTITY_DIR}" ]]; then
  identity_files=()
  while IFS= read -r -d '' file; do
    identity_files+=("$file")
  done < <(find "${IDENTITY_DIR}" -maxdepth 1 -name "*.md" -print0 2>/dev/null | sort -z)
  if [[ ${#identity_files[@]} -gt 0 ]]; then
    echo ""
    echo "## 身份档案 (${#identity_files[@]} 人)"
    for file in "${identity_files[@]}"; do
      fname="$(basename "$file" .md)"
      summary=$(awk '
        /^---$/ { count++; next }
        count == 1 && /^summary:/ {
          sub(/^summary:[[:space:]]*/, "")
          gsub(/^["'"'"']|["'"'"']$/, "")
          print
          exit
        }
      ' "$file")
      summary="${summary:-[无摘要]}"
      if [[ "$summary" =~ [一-龥] ]]; then max_len=80; else max_len=300; fi
      [[ ${#summary} -gt $max_len ]] && summary="${summary:0:$((max_len-1))}…"
      printf -- "- %s: %s\n" "$fname" "$summary"
    done
  fi
fi

