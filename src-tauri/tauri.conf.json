{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JournalClaw",
  "version": "0.11.1",
  "identifier": "com.journalclaw.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JournalClaw",
        "width": 960,
        "height": 680,
        "minWidth": 580,
        "minHeight": 400,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/speakerkit-models"
    ],
    "externalBin": [
      "binaries/journal-speech"
    ]
  }
}
